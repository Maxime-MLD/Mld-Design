---
// TODO: définir PUBLIC_WEB3FORMS_KEY dans .env (voir .env.example)
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;

const contactEmail = "contact@mld-dev.com";
const contactPhone = "06 62 59 97 71";
---

<section id="contact" class="section-y scroll-mt-24" aria-labelledby="contact-heading">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    <h2 id="contact-heading" class="max-w-2xl text-3xl lg:text-5xl" data-animate="reveal">
      Contact
    </h2>

    <div class="panel mt-16 grid grid-cols-1 lg:grid-cols-2" data-animate="reveal">
      <div class="flex flex-col justify-center gap-8 border-b border-hairline p-8 lg:border-b-0 lg:border-r lg:p-12">
        <span
          class="font-display text-lg uppercase tracking-[0.2em] text-ink"
        >
          MLD DEV
        </span>
        <p class="max-w-sm font-body text-base normal-case tracking-normal text-body">
          Une question, un projet en tête ? Parlons-en <br> je réponds sous 24h.
        </p>

        <ul class="flex flex-col gap-5">
          <li>
            <a
              href={`mailto:${contactEmail}`}
              class="group flex items-center gap-4 font-mono text-sm text-body transition-colors duration-200 hover:text-accent"
            >
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[50%] border border-hairline-strong text-muted transition-colors duration-200 group-hover:border-accent group-hover:text-accent">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M3 6h18v12H3z" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M3 7l9 6 9-6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              {contactEmail}
            </a>
          </li>
          <li>
            <a
              href={`tel:${contactPhone.replace(/\s/g, "")}`}
              class="group flex items-center gap-4 font-mono text-sm text-body transition-colors duration-200 hover:text-accent"
            >
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[50%] border border-hairline-strong text-muted transition-colors duration-200 group-hover:border-accent group-hover:text-accent">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path
                    d="M4 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L14 13l5 2v4a2 2 0 0 1-2 2C10.5 21 3 13.5 3 6a2 2 0 0 1 1-2Z"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              {contactPhone}
            </a>
          </li>
          <li>
            <a
              href="https://www.google.com/maps/search/?api=1&query=Roanne+Loire+France"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 font-mono text-sm text-body transition-colors duration-200 hover:text-accent"
            >
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[50%] border border-hairline-strong text-muted transition-colors duration-200 group-hover:border-accent group-hover:text-accent">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path
                    d="M12 21s7-7.2 7-12a7 7 0 1 0-14 0c0 4.8 7 12 7 12Z"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <circle cx="12" cy="9" r="2.5" />
                </svg>
              </span>
              Roanne, Loire (42)
            </a>
          </li>
        </ul>
      </div>

      <div class="p-8 lg:p-12">
        <form data-contact-form novalidate>
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            style="display:none"
            tabindex="-1"
            autocomplete="off"
          />

          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div class="flex flex-col gap-2">
              <label for="contact-name" class="label-mono">Nom</label>
              <input
                id="contact-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class="text-input"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="contact-email" class="label-mono">Email</label>
              <input
                id="contact-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="text-input"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="contact-phone" class="label-mono">Téléphone</label>
              <input
                id="contact-phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                class="text-input"
              />
            </div>

            <div class="flex flex-col gap-2 sm:col-span-2">
              <label for="contact-message" class="label-mono">Message</label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="5"
                class="text-input"
              ></textarea>
            </div>
          </div>

          <button type="submit" class="btn-primary mt-8 w-full sm:w-auto">
            Envoyer
          </button>

          <p
            data-contact-status
            role="status"
            aria-live="polite"
            class="mt-4 font-mono text-xs text-muted"
          ></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const status = document.querySelector<HTMLElement>("[data-contact-status]");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!status) return;

    const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    submitButton?.setAttribute("disabled", "true");
    
    // Réinitialisation de l'état visuel au départ de l'envoi
    status.classList.remove("text-red-500", "text-green-500");
    status.classList.add("text-body");
    status.textContent = "Envoi en cours…";

    try {
      const payload = Object.fromEntries(new FormData(form).entries());
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify(payload),
      });
      const result = await response.json();

      if (result.success) {
        // Succès : vert
        status.classList.remove("text-body", "text-red-500");
        status.classList.add("text-green-500");
        status.textContent = "Message envoyé, merci ! Je reviens vers vous sous 24h.";
        form.reset();
      } else {
        // Erreur API Web3Forms
        throw new Error();
      }
    } catch {
      // Erreur réseau ou rejet API : rouge
      status.classList.remove("text-body", "text-green-500");
      status.classList.add("text-red-500");
      status.textContent =
        "Une erreur est survenue. Réessayez ou écrivez-moi directement par email.";
    } finally {
      submitButton?.removeAttribute("disabled");
    }
  });
</script>
