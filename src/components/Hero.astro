---
// ---------------------------------------------------------------------------
// Fond du Hero — deux options prêtes à l'emploi, désactivées par défaut.
// Décommenter L'IMPORT correspondant ici ET le bloc de balisage plus bas
// (les deux vont ensemble), puis retirer la classe "bg-canvas" du conteneur.
// ---------------------------------------------------------------------------

// OPTION A — VIDÉO : nécessite src/assets/video/hero.mp4
import heroVideo from "../assets/video/hero_video2.0.mp4";
import heroVideoMobile from "../assets/video/hero_video_mobile.mp4";
// OPTION B — IMAGE : nécessite une image dans src/assets/images/
// import { Image } from "astro:assets";
// import heroImage from "../assets/images/hero_mld.png";
---

<section
  id="hero"
  class="relative flex h-screen w-full items-end overflow-hidden lg:items-center bg-black"
>
  <div class="absolute inset-0" data-hero-bg>
    
      <!-- ACTIVER ICI : décommenter le bloc VIDEO ou le bloc IMAGE ci-dessous
      (et l'import correspondant dans le frontmatter), puis supprimer la
      classe "bg-canvas" sur le div parent. -->

      <!-- BLOC A — VIDEO -->
<video
  class="absolute inset-0 h-full w-full object-cover object-center block md:hidden"
  autoplay
  muted
  loop
  playsinline
  webkit-playsinline
  preload="auto"
  poster="/images/hero_poster.webp"
>
  <source src={heroVideoMobile} type="video/mp4" />
</video>

<video
  class="absolute inset-0 h-full w-full object-cover object-center hidden md:block"
  autoplay
  muted
  loop
  playsinline
  webkit-playsinline
  preload="auto"
  poster="/images/hero_poster.webp"
>
  <source src={heroVideo} type="video/mp4" />
</video>
      <div class="absolute inset-0 z-10 bg-black/40"></div>
      <!-- Dégradé noire du bas de la vidéo  -->
      <div
        class="absolute inset-0 z-10 bg-hero-premium-blend"
      ></div>
      <!-- Dégradé en cercle autours de la vidéo  -->
      <div 
        class="absolute inset-0 z-10 bg-hero-radial-soft"
      ></div>

      <!-- <Image
        src={heroImage}
        alt="Réalisation MLD Dev — site vitrine responsive pour artisan"
        class="absolute inset-0 h-full w-full object-cover"
        style=""
        loading="eager"
        fetchpriority="high"
        width={1920}
        height={1080}
      />
      <div class="absolute inset-0 bg-black/80"></div> -->
  </div>

  <!-- <p class="label-mono mb-6" data-animate="reveal">
    Des sites modernes
  </p> -->
  <div class="relative z-20 mx-auto w-full max-w-[1400px] px-6 pb-24 lg:px-10 lg:pb-0">

    <h1 class="max-w-4xl text-4xl lg:text-6xl" data-animate="reveal">
      MLD Dev à Roanne <br> création de site internet
    </h1>

    <p
      class="mt-6 max-w-xl font-body text-base normal-case tracking-normal text-body lg:text-lg"
      data-animate="reveal"
    >
      Je crée des sites vitrine modernes qui donnent aux entreprises de Roanne & de la Loire (42) la visibilité qu'elles méritent.
    </p>

    <div class="mt-10" data-animate="reveal">
      <a href="#contact" class="btn-primary">Discutons de votre projet</a>
    </div>
  </div>
</section>
