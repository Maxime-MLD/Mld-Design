---
import { Image } from "astro:assets";
import { realisations } from "../data/realisations";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/realisations/*.{jpg,jpeg,png,webp}",
  { eager: true },
);
---

<section id="realisations" class="section-y scroll-mt-24" aria-labelledby="realisations-heading">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    <h2 id="realisations-heading" class="max-w-2xl text-3xl lg:text-5xl" data-animate="reveal">
      Mes Réalisations
    </h2>

    <div class="panel mt-16 p-4 lg:p-8">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:gap-6">
        {realisations.map((item) => {
          const image = images[`/src/assets/images/realisations/${item.src}`];
          const Tag = item.url ? "a" : "div";
          return (
            <Tag
              {...(item.url
                ? { href: item.url, target: "_blank", rel: "noopener noreferrer" }
                : {})}
              class="group border border-hairline bg-surface-card"
            >
              <div
                class="relative aspect-[3/2] overflow-hidden"
                data-animate="image-reveal"
              >
                {image && (
                  <Image
                    src={image.default}
                    alt={item.alt}
                    width={1200}
                    height={800}
                    loading="lazy"
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                    data-realisation-image
                  />
                )}
              </div>
              <p class="border-t border-hairline px-5 py-4 font-mono text-xs uppercase tracking-[0.15em] text-body">
                {item.title}
              </p>
            </Tag>
          );
        })}
      </div>
    </div>
  </div>
</section>
