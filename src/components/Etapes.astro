---
const steps = [
  {
    index: "01",
    title: "On échange",
    description: "Un appel pour comprendre vos besoins.",
  },
  {
    index: "02",
    title: "La maquette",
    description:
      "Je conçois la maquette de votre site et nous validons ensemble le design.",
  },
  {
    index: "03",
    title: "Je crée votre site",
    description: "Je code le site à partir de la maquette validée ensemble.",
  },
  {
    index: "04",
    title: "Livraison de votre site",
    description: "Je déploie le site en ligne et il vous appartient.",
  },
];
---

<section id="etapes" class="section-y scroll-mt-24" aria-labelledby="etapes-heading">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    <h2 id="etapes-heading" class="max-w-2xl text-3xl lg:text-5xl" data-animate="reveal">
      Les étapes
    </h2>

    <div class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4 lg:gap-8">
      {steps.map((step) => (
          <div
            class="card-glow relative overflow-hidden p-8"
            data-step-card
            data-animate="reveal"
          >
            <span class="font-display text-3xl text-muted lg:text-4xl">
              {step.index}
            </span>
            <h3 class="mt-4 text-lg lg:text-xl text-accent">{step.title}</h3>
            <p class="mt-2 font-body text-sm normal-case leading-snug tracking-normal text-ink">
              {step.description}
            </p>
          </div>
      ))}
    </div>
  </div>
</section>

