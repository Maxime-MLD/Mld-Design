  <div class="w-full" aria-hidden="true">
    <svg
      viewBox="0 0 1000 170"
      preserveAspectRatio="xMidYMid meet"
      class="block w-full"
      role="presentation"
    >
      <text
        data-wordmark-text
        x="0"
        y="169"
        font-family="Switzer, sans-serif"
        font-weight="900"
        font-size="250"
        class="fill-hairline-strong"
      >MLD DEV</text>
    </svg>
  </div>
</footer>

<script>
  // getBBox() mesure le contour vectoriel du glyphe, pas le rendu final à
  // l'écran : le hinting que Windows (ClearType/DirectWrite) applique aux
  // graisses Black décale l'encre visible du "M" de quelques pixels vers la
  // droite, sans bouger la géométrie vectorielle — invisible pour getBBox,
  // visible à l'œil. Le bord droit ("V"), lui, tombait déjà pile au bon
  // endroit. Solution : ne faire déborder le texte QUE côté gauche (rogné
  // par le <svg>, overflow hidden par défaut) pour absorber ce décalage,
  // sans toucher au bord droit qui était déjà correct.
  async function fitWordmark() {
    const text = document.querySelector<SVGTextElement>("[data-wordmark-text]");
    if (!text) return;

    try {
      await document.fonts.ready;
    } catch {
      // On continue même si la détection du chargement des polices échoue.
    }

    const viewBoxWidth = 1000;
    const leftBleed = 15; // marge de sécurité (unités de viewBox), gauche uniquement

    text.removeAttribute("transform");
    const bbox = text.getBBox();
    if (!bbox.width) return;

    // Le bord droit reste exactement où la mesure le place (final_right = viewBoxWidth) ;
    // seul le bord gauche est repoussé de leftBleed unités au-delà de 0.
    const scale = (viewBoxWidth + leftBleed) / bbox.width;
    const translateX = -leftBleed / scale - bbox.x;
    text.setAttribute("transform", `scale(${scale} 1) translate(${translateX} 0)`);
  }

  fitWordmark();
</script>
